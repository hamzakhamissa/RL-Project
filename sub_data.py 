    for ticker in ("TSLA", "NVDA", "GOOG"):
        features, prices = get_env_data(ticker)
        train_df, test_df = train_test_split(features, train_ratio=0.80)
        folds = walk_forward_folds(features, n_folds=3)
 
        print(f"\n{ticker}")
        print(f"  Total rows  : {len(features)}")
        print(f"  Train/test  : {len(train_df)} / {len(test_df)}")
        print(f"  WF folds    : {len(folds)}")
        for i, (tr, te) in enumerate(folds):
            print(f"    Fold {i+1}: train={len(tr)}  test={len(te)}")
        print(f"  Columns     : {list(features.columns)}")
        print(features[["close","returns","sma_ratio","volatility","momentum"]].tail(3).to_string())
 