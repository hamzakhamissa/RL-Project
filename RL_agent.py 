import numpy as np                          # <-- FIXED: was missing
import torch
import torch.nn as nn
import torch.optim as optim
from torch.distributions import Categorical


class ActorCritic(nn.Module):
    def __init__(self, state_dim, n_actions):
        super(ActorCritic, self).__init__()
        # The Actor: pi(a|s)
        self.actor = nn.Sequential(
            nn.Linear(state_dim, 64), nn.ReLU(),
            nn.Linear(64, n_actions), nn.Softmax(dim=-1)
        )
        # The Critic: V(s)
        self.critic = nn.Sequential(
            nn.Linear(state_dim, 64), nn.ReLU(),
            nn.Linear(64, 1)
        )


class PPOAgent:
    def __init__(self,
                 state_dim:  int,
                 n_actions:  int,
                 lr:         float = 3e-4,
                 gamma:      float = 0.99,
                 eps_clip:   float = 0.2,
                 K_epochs:   int   = 4):       # <-- FIXED: was missing
        self.gamma     = gamma
        self.eps_clip  = eps_clip
        self.K_epochs  = K_epochs              # <-- FIXED: now stored
        self.MseLoss   = nn.MSELoss()          # <-- FIXED: now stored

        self.policy     = ActorCritic(state_dim, n_actions)
        self.optimizer  = optim.Adam(self.policy.parameters(), lr=lr)
        self.policy_old = ActorCritic(state_dim, n_actions)
        self.policy_old.load_state_dict(self.policy.state_dict())

    # ------------------------------------------------------------------
    def act(self, state):
        """Sample an action from the old policy. Returns (action, log_prob)."""
        state = torch.FloatTensor(state)
        with torch.no_grad():
            probs = self.policy_old.actor(state)
        dist   = Categorical(probs)
        action = dist.sample()
        return action.item(), dist.log_prob(action)

    # ------------------------------------------------------------------
    def update(self, memory: dict):
        """PPO policy update using collected memory buffer."""
        # Convert memory to tensors
        old_states   = torch.FloatTensor(np.array(memory['states']))
        old_actions  = torch.LongTensor(np.array(memory['actions']))
        old_logprobs = torch.FloatTensor(
            [lp.item() if torch.is_tensor(lp) else lp
             for lp in memory['logprobs']])   # <-- FIXED: handle tensor logprobs

        # 1. Compute rewards-to-go (R_hat)
        rewards = []
        discounted_reward = 0
        for reward, is_terminal in zip(
                reversed(memory['rewards']),
                reversed(memory['is_terminals'])):
            if is_terminal:
                discounted_reward = 0
            discounted_reward = reward + (self.gamma * discounted_reward)
            rewards.insert(0, discounted_reward)

        rewards = torch.FloatTensor(rewards)
        # Normalise for stability
        rewards = (rewards - rewards.mean()) / (rewards.std() + 1e-5)

        # 2. Policy and value update over K_epochs
        for _ in range(self.K_epochs):
            logprobs, state_values, dist_entropy = self.evaluate(
                old_states, old_actions)

            # ratio  π_θ / π_θ_old
            ratios = torch.exp(logprobs - old_logprobs.detach())

            # Advantage estimate
            advantages = rewards - state_values.detach()

            surr1 = ratios * advantages
            surr2 = torch.clamp(
                ratios, 1 - self.eps_clip, 1 + self.eps_clip) * advantages

            # Loss = −clipped objective + value loss − entropy bonus
            loss = (-torch.min(surr1, surr2)
                    + 0.5 * self.MseLoss(state_values, rewards)
                    - 0.01 * dist_entropy)

            self.optimizer.zero_grad()
            loss.mean().backward()
            self.optimizer.step()

        # Sync old policy
        self.policy_old.load_state_dict(self.policy.state_dict())

    # ------------------------------------------------------------------
    def evaluate(self, state, action):
        """Evaluate current policy on a batch of (state, action) pairs."""
        probs         = self.policy.actor(state)
        dist          = Categorical(probs)
        logprobs      = dist.log_prob(action)
        dist_entropy  = dist.entropy()
        state_value   = self.policy.critic(state)
        return logprobs, torch.squeeze(state_value), dist_entropy

    # ------------------------------------------------------------------
    def save(self, path: str):
        """Save policy weights to disk."""
        torch.save(self.policy.state_dict(), path)

    def load(self, path: str):
        """Load policy weights from disk."""
        self.policy.load_state_dict(torch.load(path))
        self.policy_old.load_state_dict(self.policy.state_dict())