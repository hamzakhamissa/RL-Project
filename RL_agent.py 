import torch
import torch.nn as nn
import torch.optim as optim
from torch.distributions import Categorical

class ActorCritic(nn.Module):
    def __init__(self, state_dim, n_actions):
        super(ActorCritic, self).__init__()
        # The Actor: pi(a|s)
        self.actor = nn.Sequential(
            nn.Linear(state_dim, 64), nn.ReLU(),
            nn.Linear(64, n_actions), nn.Softmax(dim=-1)
        )
        # The Critic: V(s)
        self.critic = nn.Sequential(
            nn.Linear(state_dim, 64), nn.ReLU(),
            nn.Linear(64, 1)
        )

class PPOAgent:
    def __init__(self, state_dim, n_actions, lr=3e-4, gamma=0.99, eps_clip=0.2):
        self.gamma = gamma
        self.eps_clip = eps_clip # Clipping parameter
        self.policy = ActorCritic(state_dim, n_actions)
        self.optimizer = optim.Adam(self.policy.parameters(), lr=lr)
        self.policy_old = ActorCritic(state_dim, n_actions)
        self.policy_old.load_state_dict(self.policy.state_dict())
        
    def act(self, state):
        state = torch.FloatTensor(state)
        probs = self.policy_old.actor(state)
        dist = Categorical(probs)
        action = dist.sample()
        return action.item(), dist.log_prob(action)
