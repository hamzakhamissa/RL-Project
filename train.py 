Adds walk-forward cross-validation and multi-seed averaging on top of
the original training loop.

Original loop structure preserved; changes marked  # <-- CHANGED / ADDED
"""

import numpy as np                                      # <-- ADDED
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec                  # <-- ADDED

